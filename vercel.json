{
  "version": 2,
  "routes": [
    {
      "src": "/",
      "has": [
        {
          "type": "host",
          "value": "(?<subdomain>[^.]+)\\.robotlee\\.xyz"
        }
      ],
      "dest": "/$subdomain/index.html"
    },
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(?<subdomain>[^.]+)\\.robotlee\\.xyz"
        }
      ],
      "dest": "/$subdomain/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
