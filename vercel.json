{
  "version": 2,
  "routes": [
    {
      "src": "/",
      "has": [
        {
          "type": "host",
          "value": "(?<folder>auto|cad|learn|repair|tools|web)\\.robotlee\\.xyz"
        }
      ],
      "dest": "/$folder/index.html"
    },
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(?<folder>auto|cad|learn|repair|tools|web)\\.robotlee\\.xyz"
        }
      ],
      "dest": "/$folder/$1"
    },
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": ".*\\.robotlee\\.xyz"
        }
      ],
      "dest": "/404.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
