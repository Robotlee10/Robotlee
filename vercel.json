{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "(?<subdomain>[^.]+)\\.robotlee\\.xyz"
        }
      ],
      "destination": "/:subdomain/index.html"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(?<subdomain>[^.]+)\\.robotlee\\.xyz"
        }
      ],
      "destination": "/:subdomain/:path*"
    }
  ]
}
